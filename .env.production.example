# Production environment — copy to /srv/laravel-sn/.env on the server.
# This single file feeds both docker compose interpolation AND the app
# containers (env_file). Replace every CHANGE_ME before first boot.

# ── Deployment ──────────────────────────────────────────────────────────────
APP_IMAGE=ghcr.io/laravel-sn-community/laravel.sn-v2
# Pinned automatically by deploy/deploy.sh on every deploy
APP_IMAGE_TAG=latest
APP_DOMAIN=laravel-senegal.com
# Let's Encrypt expiry/problem notifications
ACME_EMAIL=CHANGE_ME@laravel-senegal.com

# ── Application ─────────────────────────────────────────────────────────────
APP_NAME="Laravel Sénégal"
APP_ENV=production
# Generate with: docker compose -f docker-compose.prod.yml run --rm --no-deps app php artisan key:generate --show
APP_KEY=
APP_DEBUG=false
APP_URL=https://laravel-senegal.com

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# stderr → visible via `docker compose logs app`
LOG_CHANNEL=stderr
LOG_LEVEL=info

# ── Database ────────────────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=laravel_sn
DB_USERNAME=laravel
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Session / Cache / Queue ─────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

CACHE_STORE=redis
QUEUE_CONNECTION=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ── Inertia SSR ─────────────────────────────────────────────────────────────
INERTIA_SSR_URL=http://ssr:13714

# ── Search (Typesense) ──────────────────────────────────────────────────────
SCOUT_DRIVER=typesense
SCOUT_QUEUE=true
# Generate with: openssl rand -hex 32
TYPESENSE_API_KEY=CHANGE_ME_LONG_RANDOM_KEY
TYPESENSE_HOST=typesense
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http

# ── Mail (real SMTP provider: Resend, Brevo, Mailgun, Postmark…) ────────────
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=CHANGE_ME.smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME
MAIL_FROM_ADDRESS="bonjour@laravel-senegal.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Backups (S3-compatible: Cloudflare R2, Backblaze B2, AWS S3…) ───────────
# Endpoint WITHOUT scheme, e.g. <account-id>.r2.cloudflarestorage.com
BACKUP_S3_ENDPOINT=CHANGE_ME
BACKUP_S3_BUCKET=laravel-sn-backups
BACKUP_S3_ACCESS_KEY_ID=CHANGE_ME
BACKUP_S3_SECRET_ACCESS_KEY=CHANGE_ME
BACKUP_CRON_EXPRESSION="0 3 * * *"
BACKUP_RETENTION_DAYS=14

# ── Legacy migration (one-off — remove after the import is done) ────────────
# LEGACY_DB_CONNECTION=mysql
# LEGACY_DB_HOST=legacy-mysql
# LEGACY_DB_PORT=3306
# LEGACY_DB_DATABASE=laravel_sn_legacy
# LEGACY_DB_USERNAME=root
# LEGACY_DB_PASSWORD=CHANGE_ME
