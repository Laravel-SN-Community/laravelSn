# Secrets — never bake env files into an image
.env
.env.*
!.env.example
!.env.production.example

# Dependencies & build artifacts (rebuilt inside the image)
node_modules
vendor
public/build
public/hot
public/storage
bootstrap/ssr
bootstrap/cache/*.php

# Runtime data — the directory skeleton is recreated in the Dockerfile
storage

# Local databases
database/*.sqlite
database/*.sqlite-journal

# Tooling & docs — not needed at runtime
.git
.github
.claude
graphify-out
tests
docker-compose.yml
docker-compose.prod.yml
Makefile
*.md
boost.json
opencode.json
GEMINI.md
phpstan.neon
pint.json
rector.php
eslint.config.js
